# Конфиг LLM-провайдера для /api/suggest эндпоинта.
# Любой OpenAI-совместимый сервис подходит.

# === Groq (бесплатный tier, быстро, рекомендую для демо) ===
# Получить ключ: https://console.groq.com/keys
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=meta-llama/llama-3.3-70b-versatile

# === Локальный Ollama ===
# Поднять: ollama pull llama3.3 && ollama serve
# Из docker-compose использовать host.docker.internal вместо localhost
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.3

# === Together.ai ===
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=...
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# === Anthropic Claude (если когда-нибудь восстановится ключ) ===
# Через Anthropic-OpenAI-compat прокси, напр. litellm.
# Из коробки наш бэк поддерживает только OpenAI-формат.
